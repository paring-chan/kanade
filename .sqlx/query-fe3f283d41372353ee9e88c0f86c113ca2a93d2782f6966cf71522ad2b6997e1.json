  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                uf.id as uf_id,\n                uf.forge_user_id as uf_forge_user_id,\n                uf.created_at as uf_created_at,\n                uf.updated_at as uf_updated_at,\n\n                f.id as f_id,\n                f.name as f_name\n            FROM user_forge uf\n            LEFT JOIN forge f ON f.id = uf.forge_id\n            WHERE uf.user_id = $1\n            ORDER BY uf.created_at\n            ",
