  "query": "\n            SELECT\n                d.upstream_id, d.downstream_id\n            FROM pipeline_job_depend d\n            INNER JOIN pipeline_job j ON j.id = d.downstream_id\n            INNER JOIN pipeline p ON p.id = j.pipeline_id\n            WHERE p.id = $1\n            ORDER BY d.downstream_id ASC\n            ",
