  "db_name": "PostgreSQL",
  "query": "\n            SELECT uf.id, uf.access_token, uf.refresh_token, uf.access_token_expires_at, uf.forge_user_id, f.config as \"forge_config: Json<ForgeConfig>\"\n            FROM user_forge uf\n            LEFT JOIN forge f ON f.id = uf.forge_id\n            WHERE\n                user_id = $1 AND\n                forge_id = $2\n            FOR UPDATE OF uf\n            ",
