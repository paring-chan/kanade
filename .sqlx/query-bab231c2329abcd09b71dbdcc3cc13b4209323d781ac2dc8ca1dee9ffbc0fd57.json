{
  "db_name": "PostgreSQL",
  "query": "\n            UPDATE pipeline_job_step s\n            SET status = CASE\n                WHEN status = 'running'::job_status THEN 'failed'::job_status\n                ELSE $1\n            END,\n                finished_at = NOW()\n            WHERE job_id = $2 AND status NOT IN ('success', 'failed', 'skipped', 'cancelled')\n            RETURNING s.id\n            ",
