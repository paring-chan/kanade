  "components": {
    "schemas": {
      "AgentPipelineJobResponse": {
        "type": "object",
        "title": "AgentPipelineJobResponse",
        "required": [
          "id",
          "name",
          "timeout"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "작업 ID"
          },
          "name": {
            "type": "string",
            "description": "작업 이름"
          },
          "timeout": {
            "type": "integer",
            "format": "int32",
            "description": "작업 타임아웃 (분 단위)"
          },
          "image": {
            "type": "string",
            "description": "컨테이너 이미지"
          }
        }
      },
      "AgentPipelineJobStepResponse": {
        "type": "object",
        "title": "AgentPipelineJobStepResponse",
        "required": [
          "id",
          "name",
          "ordering",
          "command",
          "env"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "스텝 ID"
          },
          "name": {
            "type": "string",
            "description": "스텝 이름"
          },
          "ordering": {
            "type": "integer",
            "format": "int32",
            "description": "스텝 순서(정렬용)"
          },
          "command": {
            "type": "string",
            "description": "실행 명령어"
          },
          "env": {
            "type": "object",
            "description": "스텝 스코프 환경변수 목록",
            "additionalProperties": {
              "$ref": "#/components/schemas/EnvDefinitionResponse"
            }
          }
        }
      },
      "EnvDefinitionResponse": {
        "type": "object",
        "description": "환경변수 정의",
        "anyOf": [
          {
            "$ref": "#/components/schemas/EnvDefinitionResponse_StaticEnv"
          },
          {
            "$ref": "#/components/schemas/EnvDefinitionResponse_SecretEnv"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "static": "#/components/schemas/EnvDefinitionResponse_StaticEnv",
            "secret": "#/components/schemas/EnvDefinitionResponse_SecretEnv"
          }
        }
      },
      "EnvDefinitionResponse_SecretEnv": {
        "description": "환경변수 정의",
        "allOf": [
          {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "secret"
                ],
                "example": "secret"
              }
            }
          },
          {
            "$ref": "#/components/schemas/SecretEnv"
          }
        ]
      },
      "EnvDefinitionResponse_StaticEnv": {
        "description": "환경변수 정의",
        "allOf": [
          {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "static"
                ],
                "example": "static"
              }
            }
          },
          {
            "$ref": "#/components/schemas/StaticEnv"
          }
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "title": "ErrorResponse",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "EventTypeResponse": {
        "type": "string",
        "enum": [
          "push",
          "tag",
          "release",
          "pullRequest",
          "cron",
          "manual"
        ]
      },
      "ForgeInfoResponse": {
        "type": "object",
        "title": "ForgeInfoResponse",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "포지 ID"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ForgeRepoResponse": {
        "type": "object",
        "title": "ForgeRepoResponse",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ForgeRepoSearchRequest": {
        "type": "object",
        "title": "ForgeRepoSearchRequest",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string"
          }
        }
      },
      "JobAcquireResponse": {
        "type": "object",
        "title": "JobAcquireResponse",
        "required": [
          "id",
          "job",
          "steps",
          "env",
          "secrets",
          "ssh_key"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "작업 실행 ID"
          },
          "job": {
            "description": "작업 정보",
            "allOf": [
              {
                "$ref": "#/components/schemas/AgentPipelineJobResponse"
              },
              {
                "description": "작업 정보"
              }
            ]
          },
          "steps": {
            "type": "array",
            "description": "스텝 목록",
            "items": {
              "$ref": "#/components/schemas/AgentPipelineJobStepResponse"
            }
          },
          "env": {
            "type": "object",
            "description": "Job 스코프 환경변수 목록",
            "additionalProperties": {
              "$ref": "#/components/schemas/EnvDefinitionResponse"
            }
          },
          "secrets": {
            "type": "object",
            "description": "레퍼런스된 시크릿 목록",
            "additionalProperties": {
              "type": "string"
            }
          },
          "ssh_key": {
            "type": "string"
          }
        }
      },
      "JobFinishRequest": {
        "type": "object",
        "title": "JobFinishRequest",
        "required": [
          "success"
        ],
        "properties": {
          "success": {
            "type": "boolean"
          }
        }
      },
      "JobStatusResponse": {
        "type": "string",
        "enum": [
          "waiting",
          "pending",
          "running",
          "success",
          "failed",
          "skipped",
          "cancelled"
        ]
      },
      "PipelineJobResponse": {
        "type": "object",
        "title": "PipelineJobResponse",
        "required": [
          "id",
          "key",
          "name",
          "timeout",
          "status",
          "steps",
          "parents",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "key": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "timeout": {
            "type": "integer",
            "format": "int32"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatusResponse"
          },
          "steps": {
            "type": "array",
